# ============================================================
# Auth.js v5
# Generate: openssl rand -base64 32
# ============================================================
AUTH_SECRET=

# ============================================================
# Strapi backend URL
# STRAPI_URL — для server-side (SSR, route handlers, Kubb)
# NEXT_PUBLIC_STRAPI_URL — для клиентских AI-запросов (chat/stt/tts).
# Должны указывать на один и тот же бэк.
# Local:      http://localhost:1337
# Production: https://api.yukai.app
# ============================================================
STRAPI_URL=http://localhost:1337
NEXT_PUBLIC_STRAPI_URL=http://localhost:1337

# Опционально — relay для РФ-юзеров (используется когда host = ru.yukai.app)
# Дефолт: https://relay.yukai.app/api
# NEXT_PUBLIC_AI_RELAY_URL=

AUDD_API_KEY=
