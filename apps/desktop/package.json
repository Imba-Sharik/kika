{
  "name": "kika-desktop",
  "productName": "Kika",
  "version": "0.1.4",
  "description": "Kika — AI-desktop-компаньон (ANIRUM)",
  "author": {
    "name": "ANIRUM",
    "email": "sharinigor1@gmail.com"
  },
  "private": true,
  "main": "main.js",
  "scripts": {
    "dev": "electron .",
    "build:win": "electron-builder --win --x64",
    "build:win:dir": "electron-builder --win --x64 --dir"
  },
  "devDependencies": {
    "electron": "^33.2.0",
    "electron-builder": "^26.8.1"
  },
  "dependencies": {
    "electron-updater": "^6.8.3",
    "uiohook-napi": "^1.5.5"
  },
  "build": {
    "appId": "com.anirum.kika",
    "productName": "Kika",
    "copyright": "Copyright © 2026 ANIRUM",
    "electronVersion": "33.4.11",
    "artifactName": "Kika-Setup-${arch}.${ext}",
    "directories": {
      "output": "dist",
      "buildResources": "assets"
    },
    "files": [
      "main.js",
      "preload.js",
      "selection.html",
      "selection-preload.js",
      "assets/**/*",
      "!**/*.map",
      "!**/*.md"
    ],
    "publish": {
      "provider": "github",
      "owner": "Imba-Sharik",
      "repo": "kika"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Kika"
    }
  }
}
